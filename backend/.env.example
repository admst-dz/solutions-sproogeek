# Copy to .env on the server and fill in. NEVER commit the real .env.
# SMTP_PASSWORD must be a Yandex *app password* (id.yandex.ru -> Пароли приложений),
# not the account password.
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USERNAME=info@sproogeek.com
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=info@sproogeek.com
FEEDBACK_TO=info@sproogeek.com

# Origins allowed to POST the form (comma-separated, no trailing slash).
ALLOWED_ORIGINS=https://about.sproogeek.com,https://www.sproogeek.com
